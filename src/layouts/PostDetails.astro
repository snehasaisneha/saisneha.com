---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  seriesBySlug: Record<string, { title: string }>;
};

const { post, posts, seriesBySlug } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  series,
  citations = [],
  footnotes = [],
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath, true, post.data.pubDatetime)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title, pubDatetime }, id, filePath }) => ({
  id,
  title,
  filePath,
  pubDatetime,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <div class="mx-auto w-full max-w-3xl">
      <h1
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="inline-block text-2xl font-bold text-accent sm:text-3xl"
      >
        {title}
      </h1>
      <div class="my-2 flex items-center gap-2">
        <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
        <span
          aria-hidden="true"
          class:list={[
            "max-sm:hidden",
            { hidden: !SITE.editPost.enabled || hideEditPost },
          ]}>|</span
        >
        <EditPost {hideEditPost} {post} class="max-sm:hidden" />
      </div>
      <article
        id="article"
        class="app-prose mt-8 w-full max-w-3xl prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
      >
        {
          series && series.length > 0 && (
            <div class="mb-6 flex flex-wrap items-center gap-3 rounded-xl border border-border bg-muted/20 px-4 py-3 text-sm">
              <span class="font-medium">Series</span>
              {series.map(item => {
                const slug = slugifyStr(item);
                const seriesTitle = seriesBySlug[slug]?.title ?? item;
                return (
                  <a
                    href={`/series/${slug}/`}
                    class="underline decoration-dashed underline-offset-4 hover:text-accent"
                  >
                    {seriesTitle}
                  </a>
                );
              })}
            </div>
          )
        }
        <Content />
      </article>

      {
        (citations.length > 0 || footnotes.length > 0) && (
          <div class="mt-10 space-y-8 border-t border-dashed border-border pt-8">
            {citations.length > 0 && (
              <section aria-labelledby="citations-heading" class="space-y-4">
                <h2
                  id="citations-heading"
                  class="text-xl font-semibold text-foreground"
                >
                  Citations
                </h2>
                <ol class="space-y-4">
                  {citations.map(citation => (
                    <li
                      id={`citation-${citation.id}`}
                      class="scroll-mt-16 text-base leading-8 text-foreground/85"
                    >
                      <span class="me-2 font-semibold text-foreground">
                        [{citation.id}]
                      </span>
                      <span>{citation.text}</span>
                      {(citation.doi || citation.isbn || citation.pp) && (
                        <span class="ms-2 text-sm text-foreground/70">
                          {citation.doi && <span>DOI: {citation.doi}</span>}
                          {citation.doi && citation.isbn && <span> | </span>}
                          {citation.isbn && <span>ISBN: {citation.isbn}</span>}
                          {(citation.doi || citation.isbn) && citation.pp && (
                            <span> | </span>
                          )}
                          {citation.pp && <span>pp. {citation.pp}</span>}
                        </span>
                      )}
                      {(citation.href || citation.archiveHref) && (
                        <span class="ms-2 inline-flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
                          {citation.href && (
                            <a
                              href={citation.href}
                              target="_blank"
                              rel="noreferrer noopener"
                              class="underline decoration-dashed underline-offset-4"
                            >
                              {citation.linkText ?? "Open source"}
                            </a>
                          )}
                          {citation.href && citation.archiveHref && (
                            <span class="text-foreground/55">|</span>
                          )}
                          {citation.archiveHref && (
                            <a
                              href={citation.archiveHref}
                              target="_blank"
                              rel="noreferrer noopener"
                              class="underline decoration-dashed underline-offset-4"
                            >
                              {citation.archiveLinkText ?? "Archived version"}
                            </a>
                          )}
                        </span>
                      )}
                      <a
                        href={`#citation-ref-${citation.id}`}
                        class="ms-3 text-sm underline decoration-dashed underline-offset-4"
                        aria-label={`Back to citation ${citation.id}`}
                      >
                        Back
                      </a>
                    </li>
                  ))}
                </ol>
              </section>
            )}

            {footnotes.length > 0 && (
              <section aria-labelledby="footnotes-heading" class="space-y-4">
                <h2
                  id="footnotes-heading"
                  class="text-xl font-semibold text-foreground"
                >
                  Notes
                </h2>
                <ol class="space-y-4">
                  {footnotes.map(note => (
                    <li
                      id={`footnote-${note.id}`}
                      class="scroll-mt-16 text-base leading-8 text-foreground/85"
                    >
                      <span class="me-2 font-semibold text-foreground">
                        [n {note.id}]
                      </span>
                      <span>{note.text}</span>
                      {(note.href || note.archiveHref) && (
                        <span class="ms-2 inline-flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
                          {note.href && (
                            <a
                              href={note.href}
                              target="_blank"
                              rel="noreferrer noopener"
                              class="underline decoration-dashed underline-offset-4"
                            >
                              {note.linkText ?? "Open link"}
                            </a>
                          )}
                          {note.href && note.archiveHref && (
                            <span class="text-foreground/55">|</span>
                          )}
                          {note.archiveHref && (
                            <a
                              href={note.archiveHref}
                              target="_blank"
                              rel="noreferrer noopener"
                              class="underline decoration-dashed underline-offset-4"
                            >
                              {note.archiveLinkText ?? "Archived version"}
                            </a>
                          )}
                        </span>
                      )}
                      <a
                        href={`#footnote-ref-${note.id}`}
                        class="ms-3 text-sm underline decoration-dashed underline-offset-4"
                        aria-label={`Back to note ${note.id}`}
                      >
                        Back
                      </a>
                    </li>
                  ))}
                </ol>
              </section>
            )}
          </div>
        )
      }

      <hr class="my-8 border-dashed" />

      <EditPost class="sm:hidden" {hideEditPost} {post} />

      <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
        {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
      </ul>

      <BackToTopButton />

      <ShareLinks />

      <hr class="my-6 border-dashed" />

      <!-- Previous/Next Post Buttons -->
      <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          prevPost && (
            <a
            href={getPath(prevPost.id, prevPost.filePath, true, prevPost.pubDatetime)}
              class="flex w-full gap-1 hover:opacity-75"
            >
              <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
              <div>
                <span>Previous Post</span>
                <div class="text-sm text-accent/85">{prevPost.title}</div>
              </div>
            </a>
          )
        }
        {
          nextPost && (
            <a
              href={getPath(nextPost.id, nextPost.filePath, true, nextPost.pubDatetime)}
              class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
            >
              <div>
                <span>Next Post</span>
                <div class="text-sm text-accent/85">{nextPost.title}</div>
              </div>
              <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
            </a>
          )
        }
      </div>
    </div>
  </main>
  <script
    id="post-reference-data"
    type="application/json"
    is:inline
    set:html={JSON.stringify({ citations, footnotes })}
  ></script>

  <script is:inline data-astro-rerun>
  function enhanceReferences() {
    const article = document.getElementById("article");
    const dataNode = document.getElementById("post-reference-data");
    if (!article || !dataNode?.textContent) return;

    const { citations = [], footnotes = [] } = JSON.parse(dataNode.textContent);
    const citationMap = new Map(citations.map(item => [String(item.id), item]));
    const footnoteMap = new Map(footnotes.map(item => [String(item.id), item]));
    const matcher = /\[(n\s+)?(\d+)\]/g;

    const makeReferenceNode = (kind, id, label, definition) => {
      const wrapper = document.createElement("span");
      wrapper.className = `reference-inline reference-inline--${kind}`;

      const sup = document.createElement("sup");
      sup.className = "reference-sup";

      const anchor = document.createElement("a");
      anchor.id = `${kind}-ref-${id}`;
      anchor.className = "reference-link";
      anchor.href = `#${kind}-${id}`;
      anchor.textContent = label;
      anchor.setAttribute(
        "aria-label",
        `${kind === "citation" ? "Citation" : "Note"} ${id}`
      );

      const popover = document.createElement("span");
      popover.className = "reference-popover";
      popover.setAttribute("role", "tooltip");

      const heading = document.createElement("span");
      heading.className = "reference-popover-heading";
      heading.textContent = kind === "citation" ? `Citation ${id}` : `Note ${id}`;
      popover.appendChild(heading);

      const body = document.createElement("span");
      body.className = "reference-popover-body";
      body.textContent = definition.text;
      popover.appendChild(body);

      const metaBits = [];
      if (definition.doi) metaBits.push(`DOI: ${definition.doi}`);
      if (definition.isbn) metaBits.push(`ISBN: ${definition.isbn}`);
      if (definition.pp) metaBits.push(`pp. ${definition.pp}`);

      if (metaBits.length > 0) {
        const meta = document.createElement("span");
        meta.className = "reference-popover-meta";
        meta.textContent = metaBits.join(" · ");
        popover.appendChild(meta);
      }

      if (definition.href || definition.archiveHref) {
        const links = document.createElement("span");
        links.className = "reference-popover-links";

        if (definition.href) {
          const link = document.createElement("a");
          link.className = "reference-popover-link";
          link.href = definition.href;
          link.target = "_blank";
          link.rel = "noreferrer noopener";
          link.textContent =
            definition.linkText ||
            (kind === "citation" ? "Open source" : "Open link");
          links.appendChild(link);
        }

        if (definition.href && definition.archiveHref) {
          const separator = document.createElement("span");
          separator.className = "reference-popover-separator";
          separator.textContent = "|";
          links.appendChild(separator);
        }

        if (definition.archiveHref) {
          const archiveLink = document.createElement("a");
          archiveLink.className = "reference-popover-link";
          archiveLink.href = definition.archiveHref;
          archiveLink.target = "_blank";
          archiveLink.rel = "noreferrer noopener";
          archiveLink.textContent =
            definition.archiveLinkText || "Archived version";
          links.appendChild(archiveLink);
        }

        popover.appendChild(links);
      }

      sup.appendChild(anchor);
      wrapper.appendChild(sup);
      wrapper.appendChild(popover);
      return wrapper;
    };

    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        if (!node.nodeValue?.includes("[")) return NodeFilter.FILTER_REJECT;
        const parent = node.parentElement;
        if (!parent) return NodeFilter.FILTER_REJECT;
        if (parent.closest("a, code, pre, script, style, sup")) {
          return NodeFilter.FILTER_REJECT;
        }
        return NodeFilter.FILTER_ACCEPT;
      },
    });

    const textNodes = [];
    while (walker.nextNode()) textNodes.push(walker.currentNode);

    for (const textNode of textNodes) {
      const source = textNode.nodeValue;
      if (!source) continue;

      matcher.lastIndex = 0;
      let match;
      let cursor = 0;
      let changed = false;
      const fragment = document.createDocumentFragment();

      while ((match = matcher.exec(source)) !== null) {
        const [fullMatch, notePrefix, id] = match;
        const kind = notePrefix ? "footnote" : "citation";
        const definition =
          kind === "citation" ? citationMap.get(id) : footnoteMap.get(id);

        if (!definition) continue;

        changed = true;
        if (match.index > cursor) {
          fragment.appendChild(
            document.createTextNode(source.slice(cursor, match.index))
          );
        }

        const label = kind === "citation" ? `[${id}]` : `[n ${id}]`;
        fragment.appendChild(makeReferenceNode(kind, id, label, definition));
        cursor = match.index + fullMatch.length;
      }

      if (!changed) continue;

      if (cursor < source.length) {
        fragment.appendChild(document.createTextNode(source.slice(cursor)));
      }

      textNode.parentNode?.replaceChild(fragment, textNode);
    }
  }

  enhanceReferences();

  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
  </script>
  <Footer />
</Layout>

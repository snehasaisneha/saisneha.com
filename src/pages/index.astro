---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SiteSidebar from "@/components/SiteSidebar.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const series = await getCollection("series");

const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    class="app-layout pt-8 pb-10 xl:grid xl:grid-cols-[minmax(0,1fr)_17rem] xl:gap-16"
  >
    <section>
      <section id="hero" class="border-b border-border pb-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent sm:text-sm">
          Hey! I'm Kanmani. I also go by Sneha.
        </p>
        <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-none sm:text-5xl lg:text-6xl">
          hurtling through space
        </h1>

        <p class="mt-5 max-w-2xl text-xl leading-8 sm:text-2xl">
          This is my attempt at putting my thoughts, ramblings, and musings out
          there.
        </p>
        <p class="mt-3 max-w-2xl text-base leading-8 text-foreground/80 sm:text-lg">
          Some of them are coherent, some of them are absurd, but they are all
          me. No AI is used in the writing of this blog.
        </p>

        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          <LinkButton
            href="/about"
            class="rounded-full border border-border px-4 py-2"
          >
            About
          </LinkButton>
          <LinkButton
            href="/series"
            class="rounded-full border border-border px-4 py-2"
          >
            Series
          </LinkButton>
          <LinkButton
            href="/rss.xml"
            class="rounded-full border border-border px-4 py-2"
          >
            <IconRss
              width={18}
              height={18}
              class="stroke-accent stroke-3 rtl:-rotate-90"
            />
            RSS
          </LinkButton>
        </div>
      </section>

      {recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-6">
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-3xl font-semibold tracking-wide">Recent Posts</h2>
            <LinkButton href="/blog" class="text-sm">
              All writing
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )}
    </section>

    <div class="mt-12 xl:mt-1">
      <SiteSidebar series={series} />
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

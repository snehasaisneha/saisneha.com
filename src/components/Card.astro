---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import Tag from "./Tag.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, series, tags, ...props } = data;
---

<li class="my-4">
  <article class="group border border-border bg-background px-5 py-5 transition-colors hover:bg-muted/10 sm:px-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-6">
      <div class="shrink-0 md:w-40">
        <Datetime {...props} class="text-sm" />
        {
          series && series.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {series.map(item => (
                <a
                  href={`/series/${slugifyStr(item)}/`}
                  class="rounded-full border border-border px-3 py-1 text-sm hover:border-accent hover:text-accent"
                >
                  {item}
                </a>
              ))}
            </div>
          )
        }
      </div>

      <div class="min-w-0 flex-1 border-t border-border pt-4 md:border-t-0 md:border-l md:pt-0 md:ps-6">
        <a
          href={getPath(id, filePath, true, data.pubDatetime)}
          class:list={[
            "block text-accent",
            "decoration-dashed underline-offset-4 hover:underline",
            "focus-visible:no-underline focus-visible:underline-offset-0",
          ]}
        >
          <Heading
            class="max-w-4xl text-2xl leading-tight font-semibold sm:text-3xl md:text-[2rem]"
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          >
            {title}
          </Heading>
        </a>
        <p class="mt-3 max-w-4xl text-base leading-8 text-foreground/80 sm:text-lg">
          {description}
        </p>
        {
          tags && tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2">
              {tags.map(tag => (
                <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </article>
</li>

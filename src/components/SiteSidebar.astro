---
import type { CollectionEntry } from "astro:content";
import LinkButton from "@/components/LinkButton.astro";
import Socials from "@/components/Socials.astro";
import { SITE } from "@/config";

type Props = {
  series: CollectionEntry<"series">[];
};

const { series } = Astro.props;
---

<aside class="space-y-8 xl:sticky xl:top-6">
  <section class="space-y-3">
    <span class="inline-flex text-sm font-semibold uppercase tracking-[0.2em] text-accent">
      Elsewhere
    </span>
    <p class="text-sm leading-7 text-foreground/80">
      Find me elsewhere on the internet, or subscribe via RSS.
    </p>
    <Socials class="gap-2" />
    <div class="flex flex-wrap gap-3 pt-1 text-sm">
      <LinkButton
        href="/about"
        class="rounded-full border border-border px-3 py-1.5"
      >
        About
      </LinkButton>
      <LinkButton
        href="/rss.xml"
        class="rounded-full border border-border px-3 py-1.5"
      >
        RSS
      </LinkButton>
    </div>
  </section>

  <section class="space-y-3 border-t border-border pt-6">
    <a
      href="/series"
      class="inline-flex text-sm font-semibold uppercase tracking-[0.2em] text-accent hover:opacity-75"
    >
      Series
    </a>
    <ul class="space-y-2">
      {series.map(item => (
        <li>
          <a
            href={`/series/${item.id}/`}
            class="block border-l-2 border-border/70 ps-4 py-1 text-lg leading-8 hover:border-accent hover:text-accent"
          >
            {item.data.title}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="space-y-3 border-t border-border pt-6 text-sm">
    <a
      href="/blog"
      class="inline-flex font-semibold uppercase tracking-[0.2em] text-accent hover:opacity-75"
    >
      Browse
    </a>
    <div class="flex flex-col gap-3 text-lg">
      <LinkButton href="/blog" class="w-fit">
        All writing
      </LinkButton>
      {SITE.showArchives && (
        <LinkButton href="/archives" class="w-fit">
          Archives
        </LinkButton>
      )}
      <LinkButton href="/tags" class="w-fit">
        Tags
      </LinkButton>
      <LinkButton href="/search" class="w-fit">
        Search
      </LinkButton>
    </div>
  </section>
</aside>

# Copy this file to deploy/lightsail/.env and fill in real values.

# Timezone
TZ=Asia/Kolkata

# Public hosts
LISTMONK_DOMAIN=listmonk.saisneha.com
REMARK42_DOMAIN=comments.saisneha.com

# listmonk
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change-this-admin-password
LISTMONK_DB_NAME=listmonk
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=change-this-db-password
LISTMONK_FROM_EMAIL=newsletter@mailer.saisneha.com
LISTMONK_REPLY_TO=blogging@saisneha.com

# Forward Email SMTP for listmonk
SMTP_HOST=smtp.forwardemail.net
SMTP_PORT=465
SMTP_USER=newsletter@mailer.saisneha.com
SMTP_PASSWORD=replace-with-forward-email-generated-password
SMTP_HELO_HOSTNAME=mailer.saisneha.com

# Remark42
REMARK42_SITE_ID=saisneha-com
REMARK42_SECRET=replace-with-a-long-random-string
REMARK42_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
REMARK42_GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
REMARK42_GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
